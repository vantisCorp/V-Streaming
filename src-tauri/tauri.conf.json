{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "V-Streaming",
  "version": "1.16.0",
  "identifier": "com.vantiscorp.vstreaming",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "V-Streaming",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Vantis Corp",
    "homepage": "https://github.com/vantiscorp/v-streaming",
    "category": "Video",
    "shortDescription": "Professional Video Streaming Application",
    "longDescription": "V-Streaming is a professional video streaming application with hardware acceleration and cloud rendering capabilities."
  },
  "plugins": {}
}